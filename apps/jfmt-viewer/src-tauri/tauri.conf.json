{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jfmt-viewer",
  "version": "0.0.1",
  "identifier": "io.jfmt.viewer",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "jfmt-viewer (M8.1)",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": { "active": false }
}
